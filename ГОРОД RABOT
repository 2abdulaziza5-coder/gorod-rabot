<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <style>
        :root { --main-color: #007AFF; --bg-color: #F8F9FA; }
        body { font-family: -apple-system, sans-serif; background-color: var(--bg-color); margin: 0; padding: 15px; }
        .header { text-align: center; padding: 10px 0; }
        .header h1 { font-size: 22px; color: var(--main-color); margin: 0; text-transform: uppercase; letter-spacing: 1px; }
        
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 20px; }
        .card { background: white; border-radius: 16px; padding: 20px; text-align: center; box-shadow: 0 4px 10px rgba(0,0,0,0.03); cursor: pointer; border: 1px solid #eee; }
        .card:active { transform: scale(0.97); background: #f0f0f0; }
        .card span { font-size: 35px; display: block; margin-bottom: 10px; }
        .card p { margin: 0; font-weight: bold; color: #333; }

        #form-layer { display: none; background: white; border-radius: 20px; padding: 20px; margin-top: 10px; }
        input, textarea { width: 100%; border: 1px solid #ddd; border-radius: 10px; padding: 14px; margin-bottom: 12px; box-sizing: border-box; font-size: 16px; background: #fcfcfc; }
        .btn-confirm { background: var(--main-color); color: white; border: none; width: 100%; padding: 16px; border-radius: 12px; font-weight: bold; font-size: 16px; }
        .btn-back { color: #888; background: none; border: none; padding: 10px; cursor: pointer; font-size: 14px; margin-bottom: 10px; }
    </style>
</head>
<body>

    <div id="menu-layer">
        <div class="header">
            <h1>ГОРОД RABOT 🇰🇬</h1>
            <p style="color: #666; font-size: 13px;">Бишкек: Работа и Услуги</p>
        </div>
        <div class="grid">
            <div class="card" onclick="openForm('🚚 ДОСТАВКА')"><span>📦</span><p>Доставка</p></div>
            <div class="card" onclick="openForm('🛠 УСЛУГИ')"><span>👨‍🔧</span><p>Услуги</p></div>
            <div class="card" onclick="openForm('🛒 МАРКЕТ')"><span>💰</span><p>Продать</p></div>
            <div class="card" onclick="openForm('🚕 ТАКСИ')"><span>🚕</span><p>Такси</p></div>
        </div>
    </div>

    <div id="form-layer">
        <button class="btn-back" onclick="location.reload()">← Назад в меню</button>
        <h2 id="title-cat" style="margin-top:0;">Заказ</h2>
        <input type="text" id="task-title" placeholder="Что нужно сделать?">
        <input type="number" id="task-price" placeholder="Цена в сомах">
        <textarea id="task-desc" rows="4" placeholder="Адрес, детали и ваш номер телефона"></textarea>
        <button class="btn-confirm" onclick="send()">Опубликовать в системе</button>
    </div>

    <script>
        let tg = window.Telegram.WebApp;
        tg.expand();
        let currentCat = "";

        function openForm(cat) {
            currentCat = cat;
            document.getElementById('menu-layer').style.display = 'none';
            document.getElementById('form-layer').style.display = 'block';
            document.getElementById('title-cat').innerText = cat;
        }

        function send() {
            let t = document.getElementById('task-title').value;
            let p = document.getElementById('task-price').value;
            let d = document.getElementById('task-desc').value;

            if(!t || !p) { alert("Укажите название и цену!"); return; }

            let result = { cat: currentCat, title: t, price: p, desc: d };
            tg.sendData(JSON.stringify(result));
            tg.close();
        }
    </script>
</body>
</html>
